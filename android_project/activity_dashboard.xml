<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:padding="16dp">

    <!-- Header: Futuristic Title -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPECTRAL SENSOR FUSION"
            android:textColor="#ff0033"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.2" />

        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LINK STATUS: ESTABLISHING..."
            android:textColor="#0099FF"
            android:textSize="10sp"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- EMF Readout: Large and Central -->
    <LinearLayout
        android:id="@+id/emfContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:background="#111111"
        android:padding="15dp"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ELECTROMAGNETIC FIELD (EMF)"
            android:textColor="#888888"
            android:textSize="10sp"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/emfValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00 µT"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Detected Entities List -->
    <TextView
        android:id="@+id/listHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/emfContainer"
        android:text="DETECTED ENTITIES (SORTED BY RSSI)"
        android:textColor="#888888"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="10dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/listHeader"
        android:layout_above="@id/controls">

        <LinearLayout
            android:id="@+id/entityList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Controls: Bottom Buttons -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gap="10dp">

        <Button
            android:id="@+id/vpnToggleButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:backgroundTint="#222222"
            android:text="ACTIVATE SHIELD"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <Button
            android:id="@+id/closeButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:backgroundTint="#ff0033"
            android:text="TERMINATE"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>

</RelativeLayout>
